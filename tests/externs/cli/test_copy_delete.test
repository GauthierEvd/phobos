test_dir=$(dirname $(readlink -e $0))
. $test_dir/test_env.sh
. $test_dir/setup_db.sh
. $test_dir/test_launch_daemon.sh
. $test_dir/tape_drive.sh
. $test_dir/utils_generation.sh

################################################################################
#                                    SETUP                                     #
################################################################################

function setup_raid1
{
    setup_tables
    invoke_lrs

    DIRS=(
          $(mktemp -d /tmp/test_pho.XXXX)
          $(mktemp -d /tmp/test_pho.XXXX)
         )

    $phobos dir add ${DIRS[@]}
    $phobos dir format --unlock ${DIRS[@]}
}

function setup_raid1_repl
{
    setup_tables
    invoke_lrs

    DIRS=(
          $(mktemp -d /tmp/test_pho.XXXX)
          $(mktemp -d /tmp/test_pho.XXXX)
          $(mktemp -d /tmp/test_pho.XXXX)
          $(mktemp -d /tmp/test_pho.XXXX)
         )

    $phobos dir add ${DIRS[@]}
    $phobos dir format --unlock ${DIRS[@]}
}

function setup_raid4
{
    setup_tables
    invoke_lrs

    DIRS=(
          $(mktemp -d /tmp/test_pho.XXXX)
          $(mktemp -d /tmp/test_pho.XXXX)
          $(mktemp -d /tmp/test_pho.XXXX)
          $(mktemp -d /tmp/test_pho.XXXX)
          $(mktemp -d /tmp/test_pho.XXXX)
          $(mktemp -d /tmp/test_pho.XXXX)
         )

    $phobos dir add ${DIRS[@]}
    $phobos dir format --unlock ${DIRS[@]}
}

function setup_tape_dir
{
    setup_tables
    invoke_daemons

    DIRS=($(mktemp -d /tmp/test_pho.XXXX))

    $phobos dir add ${DIRS[@]}
    $phobos dir format --unlock ${DIRS[@]}

    export drive="$(get_lto_drives 6 1)"
    export medium="$(get_tapes L6 1)"

    $phobos drive add --unlock $drive
    $phobos tape add -t LTO6 $medium
    $phobos tape format --unlock $medium
}

function cleanup
{
    if [[ -w /dev/changer ]]; then
        waive_daemons
        drain_all_drives
    else
        waive_lrs
    fi

    drop_tables

    rm -rf ${DIRS[@]}
}

function setup_dir
{
    setup_tables
    invoke_lrs

    setup_test_dirs
    # one file bigger than 1M
    setup_dummy_files 1 1k 1025
}

function cleanup_dir
{
    waive_lrs
    for dir in ${media[@]}; do
        cleanup_tmp_fs ${dir}
    done

    cleanup_dummy_files
    cleanup_test_dirs
    drop_tables
}

################################################################################
#                              TEST COPY DELETE                                #
################################################################################

function test_copy_delete_raid1()
{
    $phobos put -f dir /etc/hosts oid

    $phobos copy create -f dir oid copy-source

    $valg_phobos copy delete oid source

    local count=$($phobos copy list | wc -l)
    if [[ $count -ne 1 ]]; then
        error "There should be one copy, got $count"
    fi

    count=$($phobos extent list | wc -l)
    if [[ $count -ne 1 ]]; then
        error "There should be one extent, got $count"
    fi
}

function test_copy_delete_raid1_repl()
{
    $phobos put -f dir --lyt-params=repl_count=2 /etc/hosts oid

    $phobos copy create -f dir --lyt-params=repl_count=2 oid copy-source

    $valg_phobos copy delete oid source

    local count=$($phobos copy list | wc -l)
    if [[ $count -ne 1 ]]; then
        error "There should be one copy, got $count"
    fi

    count=$($phobos extent list --degroup | wc -l)
    if [[ $count -ne 2 ]]; then
        error "There should be two extents, got $count"
    fi
}

function test_copy_delete_raid4()
{
    $phobos put -f dir -l raid4 /etc/hosts oid

    $phobos copy create -f dir -l raid4 oid copy-source

    $valg_phobos copy delete oid source

    local count=$($phobos copy list | wc -l)
    if [[ $count -ne 1 ]]; then
        error "There should be one copy, got $count"
    fi

    count=$($phobos extent list --degroup | wc -l)
    if [[ $count -ne 3 ]]; then
        error "There should be three extents, got $count"
    fi
}

function test_copy_delete_dir_tape()
{
    $phobos put -f tape /etc/hosts oid

    $phobos copy create -f dir oid copy-source

    $valg_phobos copy delete oid source

    local count=$($phobos copy list | wc -l)
    if [[ $count -ne 1 ]]; then
        error "There should be one copy, got $count"
    fi

    count=$($phobos extent list | wc -l)
    if [[ $count -ne 1 ]]; then
        error "There should be one extent, got $count"
    fi
}

function test_copy_delete_last()
{
    $phobos put -f dir /etc/hosts oid

    $valg_phobos copy delete oid source &&
        error "Copy delete should failed, can't delete the last copy"

    local count=$($phobos copy list | wc -l)
    if [[ $count -ne 1 ]]; then
        error "There should be one copy, got $count"
    fi

    count=$($phobos extent list | wc -l)
    if [[ $count -ne 1 ]]; then
        error "There should be one extent, got $count"
    fi
}

function check_copies()
{
    local uuid=$1
    local expected_count=$2
    local output=$3
    local copy_list_filter=$4
    local expected_copy=$5
    local scope=$6

    local copies=$($phobos copy list oid -o $output -f csv --uuid $uuid $scope |
                    grep "$copy_list_filter")

    local count=$(echo "$copies" | wc -l)
    if [[ $count -ne $expected_count ]]; then
        error "There should be $expected_count copies '$expected_copy' for " \
              "uuid '$uuid', got $count"
    fi
    # Check that the last copy 'source' is for the version 1
    echo "$copies" | grep "$expected_copy"
}

function check_extents()
{
    local extent_filter=$1
    local params=$2
    local expected_count=$3

    local extents=$($phobos extent list -o object_uuid,version oid -f csv\
                    $params | grep "$extent_filter")
    count=$(echo "$extents" | wc -l)
    if [[ $count -ne $expected_count ]]; then
        error "There should be $expected_count extents for $extent_filter and" \
              "$params, got $count"
    fi
}

function test_copy_delete_deprec()
{
    $phobos put -f dir /etc/hosts oid
    local uuid_gen1=$($phobos object list -o uuid oid)
    $phobos copy create -f dir oid copy-source
    $phobos del oid

    $phobos put -f dir /etc/hosts oid
    local uuid_gen2=$($phobos object list -o uuid oid)
    $phobos copy create -f dir oid copy-source

    $phobos put -f dir --overwrite /etc/hosts oid
    $phobos copy create -f dir oid copy-source

    $valg_phobos copy delete --deprecated --version 1 oid source &&
        error "Copy delete should have failed, several copies with the same" \
              "version"

    # Delete a copy with version (should delete the copy 'source' from the
    # only alive object)
    $valg_phobos copy delete --deprecated --version 2 oid source ||
        error "Copy should be deleted"

    check_copies $uuid_gen2 1 "copy_name,version" "^source" "source,1" "-d"

    check_extents $uuid_gen2 "--copy-name source" 1

    # Delete a copy with uuid (should delete the copy 'source' from the deprec
    # object gen1)
    $valg_phobos copy delete --deprecated --uuid $uuid_gen1 oid source ||
        error "Copy should be deleted"

    check_copies $uuid_gen1 1 "copy_name,version" "copy-source" \
        "copy-source,1" "-d"

    check_extents $uuid_gen1 "" 1

    # Delete with uuid and version
    $valg_phobos copy delete --deprecated --uuid $uuid_gen2 --version 1 \
        oid source || error "Copy should be deleted"

    check_copies $uuid_gen2 1 "uuid,version" "$uuid_gen2,1" "$uuid_gen2,1" "-d"

    check_extents "$uuid_gen2,1" "" 1
}

function test_copy_delete_deprec_only()
{
    $phobos put -f dir /etc/hosts oid
    $phobos copy create -f dir oid copy-source
    local uuid_gen1=$($phobos object list -o uuid oid)
    $phobos del oid
    $phobos put -f dir /etc/hosts oid
    $phobos copy create -f dir oid copy-source
    local uuid_gen2=$($phobos object list -o uuid oid)
    $phobos put -f dir --overwrite /etc/hosts oid

    # Delete a copy 'source' from object version 1 of gen 2
    $valg_phobos copy delete --deprecated-only --version 1 --uuid $uuid_gen2 \
        oid source || error "Copy delete should have worked"

    check_copies $uuid_gen2 1 "copy_name,version" "copy-source" \
        "copy-source,1" "-D"

    check_extents "$uuid_gen2,1" "" 1

    # Delete a copy 'source' from object gen 1
    $valg_phobos copy delete --deprecated-only --uuid $uuid_gen1 oid source ||
        error "Copy delete should have worked"

    check_copies $uuid_gen1 1 "copy_name,version" "copy-source" \
        "copy-source,1" "-D"

    check_extents "$uuid_gen1,1" "" 1
}

function removed_add_to_media
{
    local removed_medium=$1

    waive_lrs
    $phobos dir delete --lost ${removed_medium} ||
        error "Dir delete should success"

    # Removed medium from media
    for i in "${!media[@]}"; do
        if [[ "${media[i]}" == "${removed_medium}" ]]; then
            unset media[$i]
            break
        fi
    done

    media=("${media[@]}")

    # clean removed medium
    cleanup_tmp_fs ${removed_medium}

    # add a new medium
    new_medium="$(make_tmp_fs 1M)"
    media+=("${new_mediuma}")
    $phobos dir add --tags copy ${new_medium} ||
        error "Dir add should success"
    invoke_lrs
    $phobos dir format --unlock ${new_medium} ||
        error "Dir format should success"
}

function delete_incomplete_object() {
    local obj_status=$1

    for split_idx in 0 1; do
        $phobos copy create -f dir --tags copy --layout raid1 \
            --lyt-params "repl_count=2" obj copy ||
                error "Copy create should success"

        if [[ "${obj_status}" == "deprecated" ]]; then
            # we can currently only create copy on living object with the CLI
            $phobos delete obj || error "Deleting object should success"
        fi

        obj_media=($($phobos extent list -f json -o media_name -c copy obj | \
                     jq -r ".[0].media_name[]"))
        for delete_idx in $((split_idx * 2)) $((split_idx * 2 +1)); do
                removed_add_to_media ${obj_media[${delete_idx}]}
        done

        $valg_phobos copy delete --all-incomplete ||
            error "Split ${split_idx} lacking," \
                  "deleting incomplete copy of a ${obj_status} object should" \
                  "success"

        copy_count="$($phobos copy list -c copy | wc -l)"
        ((copy_count == 0)) ||
            error "Split ${split_idx} lacking," \
                  "no copy should remain after deleting incomplete copy" \
                  "of a ${obj_status} object"
        ext_count="$($phobos extent list --degroup -o address | wc -l)"
        ((ext_count == 1)) ||
            error "Split ${split_idx} lacking," \
                  "1 extent should remain for the main copy of the object" \
                  "after deleting incomplete copy of a ${obj_status} object"
        if [[ "${obj_status}" == "deprecated" ]]; then
            $phobos undelete obj || error "Undeleting object should success"
        fi
    done
}

function test_copy_deleted_dir_incomplete() {
    local obj_media="$DIR_TEST_IN/tmp1"
    local copy_count
    local ext_count
    local obj_media

    mkdir ${obj_media}
    $phobos dir add --tags obj ${obj_media}
    $phobos dir format --unlock ${obj_media}

    # 4 dirs for copy raid1 repl_count=2
    media=(
        $(make_tmp_fs 1M)
        $(make_tmp_fs 1M)
        $(make_tmp_fs 1M)
        $(make_tmp_fs 1M)
    )
    $phobos dir add --tags copy ${media[@]}
    $phobos dir format --unlock ${media[@]}

    $phobos put -f dir --tags obj --layout raid1 --lyt-params "repl_count=1" \
        ${FILES[0]} obj || error "Put should success"

    # delete raid1 copy incomplete with only one lacking extent
    # extent 0 split 0
    # extent 1 split 0
    # extent 0 split 1
    # extent 1 split 1
    for ext_idx in 0 1 2 3; do
        echo "test delete raid1 copy incomplete without ext_idx ${ext_idx}"
        $phobos copy create -f dir --tags copy --layout raid1 \
            --lyt-params "repl_count=2" obj copy ||
                error "Copy create should success"


        obj_media=($($phobos extent list -f json -o media_name -c copy obj | \
                     jq -r ".[0].media_name[]"))
        removed_add_to_media ${obj_media[${ext_idx}]}

        $valg_phobos copy delete obj copy ||
            error "Dir extent ${ext_idx} lacking copy deletion should success"

        copy_count="$($phobos copy list | wc -l)"
        ((copy_count == 1)) || error "1 copy should remain"
        ext_count="$($phobos extent list --degroup -o address | wc -l)"
        ((ext_count == 1)) || error "1 extent should remain"
    done

    # delete raid1 copy incomplete with two lacking extents
    for ext_idx in 0 1 2; do
        for ext_idx_bis in `seq $((ext_idx + 1)) 3`; do
            $phobos copy create -f dir --tags copy --layout raid1 \
                --lyt-params "repl_count=2" obj copy || \
                    error "Copy create should success"

            obj_media=($($phobos extent list -f json -o media_name -c copy \
                             obj | jq -r ".[0].media_name[]"))
            removed_add_to_media ${obj_media[${ext_idx_bis}]}
            removed_add_to_media ${obj_media[${ext_idx}]}

            $valg_phobos copy delete obj copy ||
                error "Dir extents ${ext_idx} and ${ext_idx_bis} lacking" \
                      "copy deletion should success"

            copy_count="$($phobos copy list | wc -l)"
            ((copy_count == 1)) || error "1 copy should remain"
            ext_count="$($phobos extent list --degroup -o address | wc -l)"
            ((ext_count == 1)) || error "1 extent should remain"
        done
    done

    # delete raid1 copy incomplete with three lacking extents
    for ext_idx in 0 1 2 3; do
        $phobos copy create -f dir --tags copy --layout raid1 \
            --lyt-params "repl_count=2" obj copy ||
                error "Copy create should success"

        obj_media=($($phobos extent list -f json -o media_name -c copy obj | \
                     jq -r ".[0].media_name[]"))
        for delete_idx in 3 2 1 0; do
            if ((delete_idx == ext_idx)); then
                continue
            else
                removed_add_to_media ${obj_media[${delete_idx}]}
            fi
        done

        $valg_phobos copy delete obj copy ||
            error "Dir 3 extents lacking, only ${ext_idx} staying," \
                  "copy deletion should success"

        copy_count="$($phobos copy list | wc -l)"
        ((copy_count == 1)) || error "1 copy should remain"
        ext_count="$($phobos extent list --degroup -o address | wc -l)"
        ((ext_count == 1)) || error "1 extent should remain"
    done

    # delete raid1 copy incomplete without any extents
    $phobos copy create -f dir --tags copy --layout raid1 \
        --lyt-params "repl_count=2" obj copy ||
            error "Copy create should success"

    obj_media=($($phobos extent list -f json -o media_name -c copy obj | \
                 jq -r ".[0].media_name[]"))
    for delete_idx in 0 1 2 3; do
        removed_add_to_media ${obj_media[${delete_idx}]}
    done

    $valg_phobos copy delete obj copy ||
        error "Dir full incomplete copy deletion should success"

    copy_count="$($phobos copy list | wc -l)"
    ((copy_count == 1)) || error "1 copy should remain"
    ext_count="$($phobos extent list --degroup -o address | wc -l)"
    ((ext_count == 1)) || error "1 extent should remain"

    # delete one incomplete copy of a living object
    delete_incomplete_object living

    # delete one incomplete copy of a deprecated object
    delete_incomplete_object deprecated

    # incomplete protected by delay
    $phobos copy create -f dir --tags copy --layout raid1 \
        --lyt-params "repl_count=2" obj copy ||
            error "Copy create should success"

    obj_media=($($phobos extent list -f json -o media_name -c copy obj | \
                 jq -r ".[0].media_name[]"))
    removed_add_to_media ${obj_media[0]}
    removed_add_to_media ${obj_media[1]}

    PHOBOS_STORE_delete_incomplete_delay_second="3600" \
        $valg_phobos copy delete --all-incomplete ||
        error "Deleting incomplete copy with a delay should success"

    copy_count="$($phobos copy list -c copy | wc -l)"
    ((copy_count == 1)) ||
        error "Delay should protect incomplete copy"
    ext_count="$($phobos extent list --degroup -o address | wc -l)"
    ((ext_count == 3)) ||
        error "Delay should protect the extents of the incomplete copy"
}

TESTS=("setup_dir; test_copy_deleted_dir_incomplete; cleanup_dir"
       "setup_raid1; test_copy_delete_raid1; cleanup"
       "setup_raid1_repl; test_copy_delete_raid1_repl; cleanup"
       "setup_raid4; test_copy_delete_raid4; cleanup"
       "setup_raid1; test_copy_delete_last; cleanup"
       "setup_raid1; test_copy_delete_deprec; cleanup"
       "setup_raid1; test_copy_delete_deprec_only; cleanup")

if [[ -w /dev/changer ]]; then
    TESTS+=("setup_tape_dir; test_copy_delete_dir_tape; cleanup")
fi
